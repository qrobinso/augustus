# Augustus Configuration
# Copy this file to .env and fill in your actual values

# Required: API authentication key (CHANGE THIS from the default!)
# Generate a secure random string for production use
API_KEY=change-me-in-production

# Required: OpenRouter API key for LLM
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: OpenRouter model
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Optional: request structured JSON output from the analysis/facts agents (default: true).
# Most OpenRouter models support this. Set to false if your chosen model rejects
# response_format / json_schema (the agents fall back to lenient JSON parsing either way).
LLM_STRUCTURED_OUTPUTS=true

# Optional: enable provider prompt caching for the large, stable briefing system prompt
# (default: false). Only beneficial on models that support caching (e.g. Anthropic, Gemini)
# and mainly helps when many briefings are generated close together.
LLM_PROMPT_CACHE=false

# Optional: per-host research — each host independently researches the editor's
# selected stories through their persona's lens (default: true). When false, a
# single shared fact-gathering pass is used.
HOST_RESEARCH_ENABLED=true

# Optional: max web sources each host pulls per story (default: 3).
HOST_RESEARCH_MAX_SOURCES_PER_STORY=3

# Optional: persona-biased search queries generated per story, per host (default: 2).
HOST_RESEARCH_QUERIES_PER_STORY=2

# TTS Provider: piper (local, free) or elevenlabs (cloud) or gemini (cloud)
TTS_PROVIDER=piper

# Optional: ElevenLabs API key (only if using elevenlabs)
# Get one at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Optional: Google Gemini API key (only if using gemini)
# Get one at: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-tts

# Optional: NewsAPI key for additional news sources
# Get one at: https://newsapi.org
NEWS_API_KEY=

# Optional: Resend API key for email notifications
# Get one at: https://resend.com
RESEND_API_KEY=

# Content Duration Settings (in minutes)
BRIEFING_DURATION_MINUTES=7
DEEPCAST_DURATION_MINUTES=10
STATION_UPDATE_DURATION_MINUTES=3

# Content Quality Settings
# Conversation Complexity: 1 (Casual) to 5 (Expert)
CONVERSATION_COMPLEXITY=3

# Story selection: override the duration-derived story count
# (default: auto — roughly one story per 3 minutes, clamped to 1-6)
#STORIES_PER_BRIEFING=

# Include the global RSS_FEEDS in the pool even when topics are selected
# (default false: global feeds carry no topic metadata and can leak
# off-topic stories into briefings)
RSS_GLOBAL_WITH_TOPICS=false

# Briefing writer system prompt: v2 is the leaner rewrite (default).
# Set to false to A/B against the original prompt.
WRITER_PROMPT_V2=true

# Web Research Gap-Fill
# When a top story has thin scraped content/few facts, augment it with a live
# web search (DuckDuckGo) so the briefing has enough to discuss, with sources
# attributed in the script and linked per-chapter on the detail page.
WEB_RESEARCH_ENABLED=true
# Treat a story as "thin" if its content is shorter than this many characters
WEB_RESEARCH_MIN_CONTENT_CHARS=600
# ...or if it has fewer than this many gathered facts
WEB_RESEARCH_MIN_FACTS=2
# Cap how many thin stories trigger a web search per briefing (bounds latency/cost)
WEB_RESEARCH_MAX_STORIES=3

# Timezone (IANA format, e.g., America/New_York, Europe/London)
TIMEZONE=UTC

# User Personalization
USER_NAME=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Database (for Docker, use sqlite+aiosqlite:///./data/augustus.db)
DATABASE_URL=sqlite+aiosqlite:///./augustus.db

# Audio Storage Path
AUDIO_STORAGE_PATH=./audio

# Piper TTS Model Path (if using piper)
PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# Debug mode
DEBUG=false
