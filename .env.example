# Augustus Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# REQUIRED SETTINGS
# ============================================

# API Authentication Key (REQUIRED - Change this in production!)
# This key is used to authenticate API requests
API_KEY=change-me-in-production

# OpenRouter API Key (REQUIRED)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============================================
# LLM CONFIGURATION
# ============================================

# OpenRouter Model (default: anthropic/claude-3.5-sonnet)
# You can change this in the Settings UI after deployment
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# TTS CONFIGURATION
# ============================================

# TTS Provider: piper, elevenlabs, or gemini (default: piper)
TTS_PROVIDER=piper

# ElevenLabs Configuration (Optional)
# Get API key at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Google Gemini Configuration (Optional)
# Get API key at: https://aistudio.google.com
# Requires Gemini 2.0+ API key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-tts

# ============================================
# CONTENT DURATION SETTINGS
# ============================================
# These can also be configured in the Settings UI

# Daily briefing target duration in minutes (default: 7)
BRIEFING_DURATION_MINUTES=7

# DeepCast target duration in minutes (default: 10)
DEEPCAST_DURATION_MINUTES=10

# Station episode duration in minutes (default: 3)
STATION_UPDATE_DURATION_MINUTES=3

# ============================================
# CONTENT QUALITY SETTINGS
# ============================================
# These can also be configured in the Settings UI

# Conversation complexity: 1 (Casual) to 5 (Expert) (default: 3)
CONVERSATION_COMPLEXITY=3

# User timezone (IANA format, e.g., America/New_York, Europe/London)
# Default: UTC
TIMEZONE=UTC

# ============================================
# INTEGRATIONS (OPTIONAL)
# ============================================

# NewsAPI Key (Optional)
# Get one at: https://newsapi.org
# Enables additional news sources for topics
NEWS_API_KEY=

# Resend API Key (Optional)
# Get one at: https://resend.com
# Enables email notifications for scheduled briefings
RESEND_API_KEY=

# ============================================
# ADVANCED SETTINGS
# ============================================

# Debug mode (default: false)
# Set to true for verbose logging
DEBUG=false

# Database URL (default: SQLite)
# For production, consider using PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/augustus
DATABASE_URL=sqlite+aiosqlite:///./data/augustus.db

# Audio storage path (default: ./audio)
# This is relative to the container's /app directory
AUDIO_STORAGE_PATH=/app/audio
