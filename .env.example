# Augustus Configuration
# Copy this file to .env and fill in your actual values

# Required: API authentication key (CHANGE THIS from the default!)
# Generate a secure random string for production use
API_KEY=change-me-in-production

# Required: OpenRouter API key for LLM
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: OpenRouter model
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# TTS Provider: piper (local, free) or elevenlabs (cloud) or gemini (cloud)
TTS_PROVIDER=piper

# Optional: ElevenLabs API key (only if using elevenlabs)
# Get one at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Optional: Google Gemini API key (only if using gemini)
# Get one at: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview-tts

# Optional: NewsAPI key for additional news sources
# Get one at: https://newsapi.org
NEWS_API_KEY=

# Optional: Resend API key for email notifications
# Get one at: https://resend.com
RESEND_API_KEY=

# Content Duration Settings (in minutes)
BRIEFING_DURATION_MINUTES=7
DEEPCAST_DURATION_MINUTES=10
STATION_UPDATE_DURATION_MINUTES=3

# Content Quality Settings
# Conversation Complexity: 1 (Casual) to 5 (Expert)
CONVERSATION_COMPLEXITY=3

# Timezone (IANA format, e.g., America/New_York, Europe/London)
TIMEZONE=UTC

# User Personalization
USER_NAME=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Database (for Docker, use sqlite+aiosqlite:///./data/augustus.db)
DATABASE_URL=sqlite+aiosqlite:///./augustus.db

# Audio Storage Path
AUDIO_STORAGE_PATH=./audio

# Piper TTS Model Path (if using piper)
PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# Debug mode
DEBUG=false
